# Copy to .env and set SECRET_KEY and DB_PASSWORD (must match PostgreSQL user password)

SECRET_KEY=your-secret-key-change-in-production
DEBUG=True

# PostgreSQL
DB_NAME=billing_db
DB_USER=billing_user
DB_PASSWORD=your_strong_password
DB_HOST=127.0.0.1
DB_PORT=5432

# Dev server: `runserver` / `runserver 8001` listens on 0.0.0.0 so LAN IP works (not only 127.0.0.1).
# Default host comes from the part before ':' in DJANGO_DEV_BIND; default full bind is 0.0.0.0:8000.
# DJANGO_DEV_BIND=0.0.0.0:8000
# DJANGO_DEV_BIND=127.0.0.1:8000
